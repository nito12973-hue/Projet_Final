# SantéSN - Modèle de configuration d'environnement
# Copier ce fichier vers .env puis renseigner les vraies valeurs.
# Le fichier .env ne doit JAMAIS être commité.

# Sécurité
SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
# DB_ENGINE : postgresql (production) ou sqlite (développement local)
DB_ENGINE=postgresql
DB_NAME=projet_final
DB_USER=votre_utilisateur
DB_PASSWORD=votre_mot_de_passe
DB_HOST=localhost
DB_PORT=5432
